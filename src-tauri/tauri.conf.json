{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/main/tauri-v2/tauri.conf.json",
  "productName": "OpenLecture",
  "version": "0.1.0",
  "identifier": "com.openlecture.app",
  "build": {
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeDevCommand": "cd frontend && npm run dev",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenLecture",
        "width": 1200,
        "height": 800,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/openlecture-server"
    ]
  }
}
